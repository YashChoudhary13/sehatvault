# SehatVault — environment variable template.
# PLACEHOLDERS ONLY. Never put real or test secrets in this file (it is tracked in git).
# Real values live in .env.local (gitignored). Only NEXT_PUBLIC_* are exposed to the browser.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=

SUPABASE_SERVICE_ROLE_KEY=

# --- AI worker callback (web side) ---
SUPABASE_SERVICE_ROLE_KEY=
AI_CALLBACK_SECRET=
# Worker-side AI provider vars live in services/ai/.env (see services/ai/.env.example).

# --- Notifications: Telegram (next provider to implement — ADR-020) ---
TELEGRAM_BOT_TOKEN=

# --- Payments: Razorpay (TEST MODE ONLY at MVP — ADR-017) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Observability (optional) ---
SENTRY_DSN=

# --- Deferred to future production (not used at MVP; uncomment when implemented) ---
# SMS OTP via MSG91 — deferred (ADR-019: email OTP is canonical)
# MSG91_AUTH_KEY=
# WhatsApp Business / WhatsAppProvider — deferred (ADR-020)
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
